{
  "agent_id": "default",
  "token": "SAME_TOKEN_AS_HUB",
  "hub_host": "YOUR_IR_SERVER_IP_OR_DOMAIN",
  "hub_port": 9443,
  "server_name": "iron-hub",
  "ca_file": "/etc/iron/hub.crt",
  "heartbeat_seconds": 10,
  "heartbeat_timeout_seconds": 30,
  "buffer_size": 65536,
  "send_timeout_seconds": 15,
  "local_drain_timeout_seconds": 20,
  "stream_queue_size": 512,
  "max_streams": 8192,
  "connect_timeout_seconds": 15,
  "local_connect_timeout_seconds": 10,
  "max_reconnect_seconds": 30
}
