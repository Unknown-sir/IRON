{
  "agent_id": "default",
  "token": "CHANGE_ME_USE_iron_token",
  "control_host": "0.0.0.0",
  "control_port": 9443,
  "certfile": "/etc/iron/hub.crt",
  "keyfile": "/etc/iron/hub.key",
  "heartbeat_seconds": 20,
  "buffer_size": 65536,
  "ports": [
    {
      "listen_host": "0.0.0.0",
      "listen_port": 443,
      "target_host": "127.0.0.1",
      "target_port": 443
    },
    {
      "listen_host": "0.0.0.0",
      "listen_port": 8443,
      "target_host": "127.0.0.1",
      "target_port": 8443
    }
  ]
}
