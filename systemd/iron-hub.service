[Unit]
Description=IRON Secure Reverse Tunnel Hub
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/python3 /opt/iron/iron.py hub --config /etc/iron/hub.json
Restart=always
RestartSec=3
LimitNOFILE=1048576
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/etc/iron

[Install]
WantedBy=multi-user.target
